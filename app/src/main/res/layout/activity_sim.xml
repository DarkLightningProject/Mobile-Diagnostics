<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_select_sim_slot"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <Spinner
        android:id="@+id/simSlotSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/simSlotText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_sim_slot"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/carrierText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_carrier"
        android:textSize="16sp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/divider_color"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/countryText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_country"
        android:textSize="16sp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/divider_color"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/simCodeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_network_operator"
        android:textSize="16sp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/divider_color"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/volteText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_sim_state"
        android:textSize="16sp"/>

    <Button
        android:id="@+id/refreshButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_refresh_sim"
        android:layout_marginTop="10dp"
        android:layout_gravity="center_horizontal"/>

</LinearLayout>
