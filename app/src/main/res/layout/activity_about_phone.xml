<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/aboutPhoneText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/device_information"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_color"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/deviceNameText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_device"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/manufacturerText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_manufacturer"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/androidVersionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_android_version"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/kernelVersionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_kernel_version"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/imeiText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_imei"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/ramText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_total_ram"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/storageText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_internal_storage"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/modelNumberText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_model_number"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/boardText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_board"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/openGlText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_opengl_es"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/apiLevelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_api_level"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/kernelArchText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_kernel_arch"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/rootAccessText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_root_access"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/googlePlayServicesText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_google_play"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/uptimeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_uptime"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <ImageView
            android:id="@+id/phoneHardwareImage"
            android:layout_width="400dp"
            android:layout_height="400dp"
            android:layout_marginTop="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/phone_hardware_image"
            android:contentDescription="@string/phone_hardware_desc"/>

    </LinearLayout>

</ScrollView>
